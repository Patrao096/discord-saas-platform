datasource db {
  provider = "postgresql"
  url      = env("DATABASE_URL")
}

generator client {
  provider = "prisma-client-js"
}

enum PlanStatus {
  FREE
  PRO
  ENTERPRISE
}

model User {
  id               String   @id @default(cuid())
  discordId        String   @unique
  username         String
  discriminator    String
  avatar           String?
  accessToken      String   // Para operações em nome do usuário
  refreshToken     String
  
  // Billing
  stripeCustomerId String?  @unique
  plan             PlanStatus @default(FREE)
  planExpiresAt    DateTime?

  // Relacionamentos
  bots             Bot[]
  createdAt        DateTime @default(now())
}

model Bot {
  id            String   @id @default(cuid())
  name          String
  botToken      String   // Criptografado!
  clientId      String   @unique
  guildId       String   @unique // Um bot por servidor neste modelo
  prefix        String   @default("!")
  
  isActive      Boolean  @default(true)
  ownerId       String
  owner         User     @relation(fields: [ownerId], references: [id])
  
  // Configurações Dinâmicas (JSON)
  modules       Json     @default("{\"welcome\": false, \"moderation\": true}")
  
  createdAt     DateTime @default(now())
  updatedAt     DateTime @updatedAt
}

model Plan {
  id          String   @id @default(cuid())
  name        String
  description String
  price       Float
  maxBots     Int      @default(1)
  active      Boolean  @default(true)
  order       Int      @default(0)
}